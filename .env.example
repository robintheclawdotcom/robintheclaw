# Copy to .env and fill in. Never commit .env. Keys are read from 0600 files, never from here.

# Robinhood Chain
RH_MAINNET_RPC=https://rpc.mainnet.chain.robinhood.com
RH_TESTNET_RPC=https://rpc.testnet.chain.robinhood.com
RH_CHAIN_ID=4663
RH_TESTNET_CHAIN_ID=46630

# Deploy key path (a 0600 file holding a hex private key). Used by forge script only.
# DEPLOYER_KEYFILE=
# CF_API_TOKEN_FILE=keys/cloudflare-api-token
# RENDER_API_KEY_FILE=keys/render-api-token

# Lighter perp API (read-only public endpoints need no auth)
LIGHTER_API=https://mainnet.zklighter.elliot.ai
LIGHTER_WEBSOCKET=wss://mainnet.zklighter.elliot.ai/stream?readonly=true

# Private research runtime. Configure these only in managed worker settings or ignored local files.
# DATABASE_URL=
# R2_BUCKET=
# AWS_ENDPOINT_URL=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=auto
# RUNTIME_CONFIG=../config/addresses.json
# RUST_LOG=info
